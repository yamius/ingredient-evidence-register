  "license": "https://creativecommons.org/licenses/by/4.0/",
  "version": "1.1.0",
  "datePublished": "2026-07-15",
  "keywords": [
    "skincare ingredients",
    "cosmetic ingredients",
    "evidence grading",
    "dermatology",
    "open data",
    "evidence-based skincare"
  ],
  "citeAs": "Bilenko, Jacob (2026). Vallydia Ingredient-Evidence Register (Version 1.1.0) [Data set]. Vallydia. https://doi.org/10.5281/zenodo.21364453",
